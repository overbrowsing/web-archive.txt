{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "web-archive.txt v0.1 schema",
  "type": "object",

  "required": ["version", "last_updated", "archive"],

  "properties": {
    "version": {
      "type": "string",
      "description": "Specification version identifier (schema version, not deployment version)"
    },

    "last_updated": {
      "type": "string",
      "description": "The date the web-archive.txt file was last updated, in RFC9557 full-date format (YYYY-MM-DD).",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "archive": {
      "type": "object",
      "required": ["id", "name", "website"],

      "properties": {
        "id": {
          "type": "string",
          "description": "Stable machine-readable web archive identifier consisting of 2-6 lowercase alphanumeric characters",
          "pattern": "^[a-z0-9]{2,6}$"
        },

        "name": {
          "$ref": "#/definitions/namedEntity"
        },

        "established": {
          "type": "string",
          "description": "Web archive establishment year, in RFC9557 year format (YYYY)",
          "pattern": "^\\d{4}$"
        },

        "website": {
          "type": "string",
          "description": "Canonical public web archive website URL",
          "pattern": "^https?://.+$"
        },

        "email": {
          "type": "string",
          "description": "Administrative or operational contact email address",
          "format": "email"
        },

        "organisation": {
          "type": "object",
          "required": ["name", "type"],

          "properties": {
            "name": {
              "$ref": "#/definitions/namedEntity"
            },

            "type": {
              "type": "string",
              "description": "Institutional classification. Values MAY include: national_archive, national_library, state_archive, state_library, university, research_institute, government, nonprofit, commercial, community"
            },

            "location": {
              "type": "array",
              "description": "Jurisdiction identifiers using ISO 3166-1 or ISO 3166-2 codes. The property MAY contain multiple jurisdiction identifiers representing hierarchical or overlapping jurisdictions.",
              "items": { "type": "string" }
            },

            "website": {
              "type": "string",
              "description": "Canonical organisation website URL",
              "pattern": "^https?://.+$"
            }
          },

          "additionalProperties": false
        },

        "scope": {
          "type": "object",
          "required": ["crawl", "authority"],

          "properties": {
            "crawl": {
              "type": "array",
              "description": "Crawl modalities (harvesting methods) used by the web archive. Values MAY include: 'national_domain', 'regional_domain', 'bulk', 'selective', 'event', 'thematic', 'periodical'",
              "items": { "type": "string" }
            },

            "authority": {
              "type": "object",
              "required": ["type"],

              "properties": {
                "type": {
                  "type": "string",
                  "description": "Authority model. Values MAY include: 'legal_deposit', 'public_record', 'institutional', 'voluntary', 'research'"
                },

                "documentation": {
                  "type": "string",
                  "description": "Reference describing the collection authority",
                  "pattern": "^https?://.+$"
                }
              },

              "additionalProperties": false
            },

            "coverage": {
              "type": "string",
              "description": "Temporal coverage interval, in RFC9557 date format (YYYY-MM-DD). Supports open-ended (YYYY-MM-DD/..) and bounded (YYYY-MM-DD/YYYY-MM-DD) intervals",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}(?:/\\.\\.|/\\d{4}-\\d{2}-\\d{2})$"
            },

            "domains": {
              "type": "array",
              "description": "Domain scope indicators including ccTLDs, gTLDs and geoTLDs",
              "items": { "type": "string" }
            },

            "collections": {
              "type": "array",
              "description": "Enables collection-scoped resolution. When defined, API and replay URI templates MAY include the {collection} variable",

              "items": {
                "type": "object",
                "required": ["id", "name"],

                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Stable machine-readable collection identifier"
                  },

                  "name": {
                    "type": "string",
                    "description": "Human-readable collection name"
                  },

                  "coverage": {
                    "type": "string",
                    "description": "Collection-specific temporal coverage interval, in RFC9557 date format (YYYY-MM-DD). Supports open-ended (YYYY-MM-DD/..) and bounded (YYYY-MM-DD/YYYY-MM-DD) intervals",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}(?:/\\.\\.|/\\d{4}-\\d{2}-\\d{2})$"
                  }
                },

                "additionalProperties": false
              }
            }
          },

          "additionalProperties": false
        }
      },

      "additionalProperties": false
    },

    "api": {
      "type": "object",

      "properties": {
        "documentation": {
          "type": "string",
          "description": "URL to API documentation or developer resources",
          "pattern": "^https?://.+$"
        },

        "rate_limit": {
          "type": "boolean",
          "description": "Indicates whether rate limiting is enforced"
        },

        "memento": {
          "type": "object",

          "properties": {
            "timemap": { "$ref": "#/definitions/endpointDatetime" },
            "timegate": { "$ref": "#/definitions/endpointDatetime" }
          },

          "additionalProperties": false
        },

        "cdx": {
          "type": "object",

          "properties": {
            "query": { "$ref": "#/definitions/endpointUrl" }
          },

          "additionalProperties": false
        }
      },

      "additionalProperties": false
    },

    "replay": {
      "type": "object",

      "properties": {
        "rewritten": {
          "type": "string",
          "description": "Standard replay mode with web archive rewriting enabled",
          "pattern": "^(?=https?://)(?=.*\\{url\\})(?=.*\\{datetime\\}).*$"
        },

        "no_toolbar": {
          "type": "string",
          "description": "Replay mode without toolbar or banner injection",
          "pattern": "^(?=https?://)(?=.*\\{url\\})(?=.*\\{datetime\\}).*$"
        },

        "raw": {
          "type": "string",
          "description": "Replay mode exposing minimally rewritten archived content",
          "pattern": "^(?=https?://)(?=.*\\{url\\})(?=.*\\{datetime\\}).*$"
        }
      },

      "additionalProperties": false
    }
  },

  "additionalProperties": false,

  "definitions": {
    "nameObject": {
      "type": "object",
      "required": ["text"],

      "properties": {
        "text": { "type": "string" },
        "en": { "type": "string" },
        "alt": { "type": "string" }
      },

      "additionalProperties": false
    },

    "namedEntity": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/definitions/nameObject" },
        {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string" },
              { "$ref": "#/definitions/nameObject" }
            ]
          },
          "minItems": 1,
          "maxItems": 2
        }
      ]
    },

    "endpointUrl": {
      "type": "object",
      "required": ["endpoint", "access"],

      "properties": {
        "endpoint": {
          "type": "string",
          "pattern": "^https?://.+$"
        },

        "access": {
          "type": "string",
          "description": "online | offline | local"
        }
      },

      "additionalProperties": false
    },

    "endpointDatetime": {
      "type": "object",
      "required": ["endpoint", "access"],

      "properties": {
        "endpoint": {
          "type": "string",
          "pattern": "^https?://.+$"
        },

        "access": {
          "type": "string",
          "description": "online | offline | local"
        }
      },

      "additionalProperties": false
    }
  }
}